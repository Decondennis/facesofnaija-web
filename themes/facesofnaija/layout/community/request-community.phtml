<script type="text/javascript">
	<?php 
$js_array = json_encode($wo['community_sub_categories']);
echo "var sub_categories_array = ". $js_array . ";\n";
?>
	function GetCommunitySubCategory(self) {
		id = $(self).val();
		var text = "";
		if (typeof(sub_categories_array[id]) == 'undefined') {
			$('#community_sub_category').html('');
		}
		else{
			sub_categories_array[id].forEach(function(entry) {
				text = text + "<option value='"+entry.id+"'>"+entry.lang+"</option>";
			});
			$('#community_sub_category').html(text);
		}
	}
   $(document).ready(function() {
	 // Check if ajaxForm is available
	 if (typeof $.fn.ajaxForm !== 'undefined') {
	   $('form.request-community-form').ajaxForm({
		 url: Wo_Ajax_Requests_File() + '?f=communities&s=request_community',
		 dataType: 'json',
		 beforeSend: function() {
		   $('.request-community-form').find('.add_wow_loader').addClass('btn-loading');
		   $('.app-general-alert').html('');
		 },
		 success: function(data) {
		   scrollToTop();
		   if (data.status == 200) {
			 $('.app-general-alert').html('<div class="alert alert-success">' + data.message + '</div>');
			 $('.alert-success').fadeIn(300);
			 // Clear form
			 $('.request-community-form')[0].reset();
		   } else {
			   var errors = data.errors.join("<br>");
			   $('.app-general-alert').html('<div class="alert alert-danger">' + errors + '</div>');
			   $('.alert-danger').fadeIn(300);
		   }
		   $('.request-community-form').find('.add_wow_loader').removeClass('btn-loading');
		 },
		 error: function(xhr, status, error) {
		   $('.app-general-alert').html('<div class="alert alert-danger">Error submitting request. Please try again.</div>');
		   $('.alert-danger').fadeIn(300);
		   $('.request-community-form').find('.add_wow_loader').removeClass('btn-loading');
		   console.log('XHR Error:', xhr.responseText);
		 }
	   });
	 } else {
	   // Fallback: Use regular AJAX submit
	   $('form.request-community-form').on('submit', function(e) {
		 e.preventDefault();
		 var formData = $(this).serialize();

		 $('.request-community-form').find('.add_wow_loader').addClass('btn-loading');
		 $('.app-general-alert').html('');

		 $.ajax({
		   url: Wo_Ajax_Requests_File() + '?f=communities&s=request_community',
		   type: 'POST',
		   data: formData,
		   dataType: 'json',
		   success: function(data) {
			 scrollToTop();
			 if (data.status == 200) {
			   $('.app-general-alert').html('<div class="alert alert-success">' + data.message + '</div>');
			   $('.alert-success').fadeIn(300);
			   $('.request-community-form')[0].reset();
			 } else {
			   var errors = data.errors.join("<br>");
			   $('.app-general-alert').html('<div class="alert alert-danger">' + errors + '</div>');
			   $('.alert-danger').fadeIn(300);
			 }
			 $('.request-community-form').find('.add_wow_loader').removeClass('btn-loading');
		   },
		   error: function(xhr, status, error) {
			 $('.app-general-alert').html('<div class="alert alert-danger">Error submitting request. Please try again.</div>');
			 $('.alert-danger').fadeIn(300);
			 $('.request-community-form').find('.add_wow_loader').removeClass('btn-loading');
			 console.log('AJAX Error:', xhr.responseText);
		   }
		 });
	   });
	 }
   });
</script>
