  </div>
</div>
<script>
function ApproveCreation(id, btn) {
  $(btn).attr('disabled', true).text('Please wait..');
  $.post(Wo_Ajax_Requests_File()+"?f=admin_setting&s=approve_creation_request", {id: id}, function (data) {
    if (data.status == 200) {
      $('#creation_req_'+id).fadeOut(300, function(){ $(this).remove(); });
    } else {
      alert(data.error || 'Failed');
      $(btn).attr('disabled', false).text('Approve');
    }
  }, 'json');
}
function DeclineCreation(id, btn) {
  $(btn).attr('disabled', true).text('Please wait..');
  $.post(Wo_Ajax_Requests_File()+"?f=admin_setting&s=decline_creation_request", {id: id}, function (data) {
    if (data.status == 200) {
      $('#creation_req_'+id).fadeOut(300, function(){ $(this).remove(); });
    } else {
      alert(data.error || 'Failed');
      $(btn).attr('disabled', false).text('Decline');
    }
  }, 'json');
}
</script>
<script>
$(function(){
  $('#check-all-requests').on('change', function(){
    $('.req-checkbox').prop('checked', this.checked).trigger('change');
  });
  $(document).on('change', '.req-checkbox', function(){
    var any = $('.req-checkbox:checked').length > 0;
    $('#bulk-approve').prop('disabled', !any);
    $('#bulk-decline').prop('disabled', !any);
  });
  $('#bulk-approve').on('click', function(){
    var ids = $('.req-checkbox:checked').map(function(){ return $(this).val(); }).get();
    if (!ids.length) return;
    $(this).prop('disabled', true).text('Please wait..');
    $.post(Wo_Ajax_Requests_File()+"?f=admin_setting&s=approve_creation_requests_bulk", {ids: ids}, function(data){
      if (data.status == 200) {
        ids.forEach(function(id){ $('#creation_req_'+id).remove(); });
      } else {
        alert(data.error || 'Failed');
      }
      $('#bulk-approve').prop('disabled', true).text('Approve Selected');
    }, 'json');
  });
  $('#bulk-decline').on('click', function(){
    var ids = $('.req-checkbox:checked').map(function(){ return $(this).val(); }).get();
    if (!ids.length) return;
    $(this).prop('disabled', true).text('Please wait..');
    $.post(Wo_Ajax_Requests_File()+"?f=admin_setting&s=decline_creation_requests_bulk", {ids: ids}, function(data){
      if (data.status == 200) {
        ids.forEach(function(id){ $('#creation_req_'+id).remove(); });
      } else {
        alert(data.error || 'Failed');
      }
      $('#bulk-decline').prop('disabled', true).text('Decline Selected');
    }, 'json');
  });
});
</script>
