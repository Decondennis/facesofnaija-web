          <tbody>
            <?php if (!empty($requests)) {
              foreach ($requests as $r) {
                $user = $db->objectBuilder()->where('user_id', $r['user_id'])->getOne('Wo_Users');
                $time = date('Y-m-d H:i', $r['time']);
                ?>
                <tr id="creation_req_<?php echo $r['id']; ?>">
                  <td><input type="checkbox" class="req-checkbox" value="<?php echo $r['id']; ?>"></td>
                  <td><?php echo $r['id']; ?></td>
                  <td><?php echo (!empty($user) ? $user->name . ' (@' . $user->username . ')' : $r['user_id']); ?></td>
                  <td><?php echo $r['community_name']; ?></td>
                  <td><?php echo $r['community_title']; ?></td>
                  <td><?php echo (isset($r['category']) ? $r['category'] : ''); ?></td>
                  <td><?php echo (isset($r['privacy']) && $r['privacy'] == 2 ? 'Private' : 'Public'); ?></td>
                  <td><?php echo $time; ?></td>
                  <td>
                    <button class="btn btn-success btn-sm" onclick="ApproveCreation(<?php echo $r['id']; ?>, this)">Approve</button>
                    <button class="btn btn-danger btn-sm" onclick="DeclineCreation(<?php echo $r['id']; ?>, this)">Decline</button>
                  </td>
                </tr>
              <?php }
            } else { ?>
              <tr><td colspan="8" class="text-center">No creation requests found.</td></tr>
            <?php } ?>
