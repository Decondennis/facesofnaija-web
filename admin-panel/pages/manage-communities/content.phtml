        <script>
        $(document).on('click', '#review-creation-requests-btn', function(e){
            e.preventDefault();
            console.log('Review Creation Requests clicked');
            $('#creation-requests-body').html('<div class="text-center">Loading...</div>');
            $('#CreationRequestsModal').modal('show');
            $.ajax({
                url: Wo_Ajax_Requests_File()+"?f=admin_setting&s=get_creation_requests",
                method: 'POST',
                dataType: 'text',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                data: {},
                success: function(resp) {
                    var data = null;
                    try {
                        data = JSON.parse(resp);
                    } catch (e) {
                        // Not JSON — likely HTML (login page or full admin page). Show it for debugging.
                        var trimmed = (resp || '').trim();
                        if (trimmed.charAt(0) === '<') {
                            $('#creation-requests-body').html('<div style="max-height:60vh;overflow:auto;"><pre style="white-space:pre-wrap;">'+$('<div>').text(trimmed).html()+'</pre></div>');
                        } else {
                            $('#creation-requests-body').html('<div class="text-center">Unable to load requests</div>');
                        }
                        return;
                    }
                    if (data && data.status == 200) {
                        $('#creation-requests-body').html(data.html);
                    } else {
                        $('#creation-requests-body').html('<div class="text-center">Unable to load requests</div>');
                    }
                },
                error: function(xhr) {
                    var text = xhr.responseText || 'Unable to load requests';
                    $('#creation-requests-body').html('<pre style="white-space:pre-wrap;">'+$('<div>').text(text).html()+'</pre>');
                }
            });
        });
        function OpenCommunityRequests(community_id) {
            $('#requests-body').html('<div class="text-center">Loading...</div>');
            $('#RequestsModal').modal('show');
            $.post(Wo_Ajax_Requests_File()+"?f=admin_setting&s=get_community_requests", {community_id: community_id}, function (data) {
                if (data.status == 200) {
                    $('#requests-body').html(data.html);
                } else {
                    $('#requests-body').html('<div class="text-center">Unable to load requests</div>');
                }
            }, 'json');
        }
        function ApproveRequest(user_id, community_id, btn) {
            $(btn).attr('disabled', true).text('Please wait..');
            $.post(Wo_Ajax_Requests_File()+"?f=admin_setting&s=approve_community_join", {user_id: user_id, community_id: community_id}, function (data) {
                if (data.status == 200) {
                    $('#community_request_'+user_id).fadeOut(300, function(){ $(this).remove(); });
                } else {
                    alert(data.error || 'Failed');
                    $(btn).attr('disabled', false).text('Approve');
                }
            }, 'json');
        }
        function DeclineRequest(user_id, community_id, btn) {
            $(btn).attr('disabled', true).text('Please wait..');
            $.post(Wo_Ajax_Requests_File()+"?f=admin_setting&s=decline_community_join", {user_id: user_id, community_id: community_id}, function (data) {
                if (data.status == 200) {
                    $('#community_request_'+user_id).fadeOut(300, function(){ $(this).remove(); });
                } else {
                    alert(data.error || 'Failed');
                    $(btn).attr('disabled', false).text('Decline');
                }
            }, 'json');
        }
        </script>

        <script>
        function ApproveCreation(id, btn) {
            $(btn).attr('disabled', true).text('Please wait..');
            $.ajax({
                url: Wo_Ajax_Requests_File()+"?f=admin_setting&s=approve_creation_request",
                method: 'POST',
                dataType: 'json',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                data: {id: id},
                success: function(data) {
                    if (data.status == 200) {
                        $('#creation_req_'+id+' td:last').html('<span class="badge badge-success">Approved</span>');
                        $(btn).attr('disabled', true).text('Approved');
                    } else {
                        alert(data.error || 'Failed');
                        $(btn).attr('disabled', false).text('Approve');
                    }
                },
                error: function(xhr) {
                    alert(xhr.responseText || 'Failed');
                    $(btn).attr('disabled', false).text('Approve');
                }
            });
        }
        function DeclineCreation(id, btn) {
            $(btn).attr('disabled', true).text('Please wait..');
            $.ajax({
                url: Wo_Ajax_Requests_File()+"?f=admin_setting&s=decline_creation_request",
                method: 'POST',
                dataType: 'json',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                data: {id: id},
                success: function(data) {
                    if (data.status == 200) {
                        $('#creation_req_'+id+' td:last').html('<span class="badge badge-danger">Declined</span>');
                        $(btn).attr('disabled', true).text('Declined');
                    } else {
                        alert(data.error || 'Failed');
                        $(btn).attr('disabled', false).text('Decline');
                    }
                },
                error: function(xhr) {
                    alert(xhr.responseText || 'Failed');
                    $(btn).attr('disabled', false).text('Decline');
                }
            });
        }

        $(document).on('change', '#CreationRequestsModal .req-checkbox', function(){
            var any = $('#CreationRequestsModal .req-checkbox:checked').length > 0;
            $('#CreationRequestsModal #bulk-approve').prop('disabled', !any);
            $('#CreationRequestsModal #bulk-decline').prop('disabled', !any);
        });
        $(document).on('click', '#CreationRequestsModal #check-all-requests', function(){
            var checked = $(this).is(':checked');
            $('#CreationRequestsModal .req-checkbox').prop('checked', checked).trigger('change');
        });
        $(document).on('click', '#CreationRequestsModal #bulk-approve', function(){
            var ids = $('#CreationRequestsModal .req-checkbox:checked').map(function(){ return $(this).val(); }).get();
            if (!ids.length) return;
            $(this).prop('disabled', true).text('Please wait..');
            $.ajax({
                url: Wo_Ajax_Requests_File()+"?f=admin_setting&s=approve_creation_requests_bulk",
                method: 'POST',
                dataType: 'json',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                data: {ids: ids},
                success: function(data) {
                    if (data.status == 200) {
                        ids.forEach(function(id){ $('#creation_req_'+id+' td:last').html('<span class="badge badge-success">Approved</span>'); });
                    } else {
                        alert(data.error || 'Failed');
                    }
                    $('#CreationRequestsModal #bulk-approve').prop('disabled', true).text('Approve Selected');
                },
                error: function(xhr) {
                    alert(xhr.responseText || 'Failed');
                    $('#CreationRequestsModal #bulk-approve').prop('disabled', true).text('Approve Selected');
                }
            });
        });
        $(document).on('click', '#CreationRequestsModal #bulk-decline', function(){
            var ids = $('#CreationRequestsModal .req-checkbox:checked').map(function(){ return $(this).val(); }).get();
            if (!ids.length) return;
            $(this).prop('disabled', true).text('Please wait..');
            $.ajax({
                url: Wo_Ajax_Requests_File()+"?f=admin_setting&s=decline_creation_requests_bulk",
                method: 'POST',
                dataType: 'json',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                data: {ids: ids},
                success: function(data) {
                    if (data.status == 200) {
                        ids.forEach(function(id){ $('#creation_req_'+id+' td:last').html('<span class="badge badge-danger">Declined</span>'); });
                    } else {
                        alert(data.error || 'Failed');
                    }
                    $('#CreationRequestsModal #bulk-decline').prop('disabled', true).text('Decline Selected');
